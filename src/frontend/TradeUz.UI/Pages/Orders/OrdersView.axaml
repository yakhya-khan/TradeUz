<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:TradeUz.UI.Pages.Orders"
             xmlns:controls="clr-namespace:TradeUz.UI.Controls.Inputs"
             xmlns:common="clr-namespace:TradeUz.UI.Pages.Common"
             xmlns:i="using:Avalonia.Xaml.Interactivity"
             xmlns:behaviors="clr-namespace:TradeUz.UI.Controls.Behaviors"
             mc:Ignorable="d"
             d:DesignWidth="1240"
             d:DesignHeight="820"
             x:Class="TradeUz.UI.Pages.Orders.OrdersView"
             x:DataType="vm:OrdersViewModel">
    <Design.DataContext>
        <vm:OrdersViewModel />
    </Design.DataContext>
    <Grid RowDefinitions="50,*" >
        <controls:NumericBox
            Classes="AmountInput"
            Value="{Binding CurrentPrice}"
            DecimalPlaces="6"
            UseGrouping="True"
            PadFractionZerosOnBlur="False"
            Width="200"
            Height="36">
            
        </controls:NumericBox>
        
        <TextBlock Grid.Row="1" Classes="PageTitle" Text="{Binding Title}"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"/>
    </Grid>
</UserControl>
