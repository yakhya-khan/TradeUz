<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:TradeUz.UI.Pages.Sales"
             mc:Ignorable="d"
             d:DesignWidth="1200"
             d:DesignHeight="940"
             x:Class="TradeUz.UI.Pages.Sales.SalesView"
             x:DataType="vm:SalesViewModel">
    <Design.DataContext>
        <vm:SalesViewModel />
    </Design.DataContext>

    <Border Background="{DynamicResource PrimaryBackground}" Padding="22">
        <Grid ColumnDefinitions="3*,2*" RowDefinitions="Auto,*" RowSpacing="22" ColumnSpacing="22">
            <Border Grid.ColumnSpan="2"
                    Padding="28"
                    CornerRadius="20"
                    Background="{DynamicResource SurfaceDefault}">
                <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Sales Window"
                                   FontSize="30"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryForeground}" />
                        <TextBlock Text="Complete sales faster: add items, select customer, and finish payment in one flow."
                                   FontSize="14"
                                   Foreground="{DynamicResource SecondaryForeground}" />
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                Spacing="10"
                                HorizontalAlignment="Right">
                        <Border Background="{DynamicResource SurfaceHover}" Padding="14,8" CornerRadius="12">
                            <TextBlock Text="Shift #0124"
                                       FontWeight="Medium"
                                       Foreground="{DynamicResource AccentBlue}" />
                        </Border>
                        <Button Content="New Sale"
                                Background="{DynamicResource AccentBlue}"
                                Foreground="{DynamicResource PrimaryHoverForeground}"
                                Padding="18,8"
                                CornerRadius="12" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Padding="22"
                    CornerRadius="20"
                    Background="{DynamicResource SurfaceDefault}">
                <Grid RowDefinitions="Auto,Auto,Auto,*,Auto,Auto" RowSpacing="16">
                    <TextBlock Text="Cart"
                               FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryForeground}" />

                    <Border Grid.Row="1" Background="{DynamicResource SurfaceHover}" Padding="14" CornerRadius="12">
                        <Grid ColumnDefinitions="2.6*,1.2*,1.2*,1*">
                            <TextBlock Text="Item" FontWeight="Medium" Foreground="{DynamicResource SecondaryForeground}" />
                            <TextBlock Grid.Column="1" Text="Qty" FontWeight="Medium" Foreground="{DynamicResource SecondaryForeground}" HorizontalAlignment="Center" />
                            <TextBlock Grid.Column="2" Text="Price" FontWeight="Medium" Foreground="{DynamicResource SecondaryForeground}" HorizontalAlignment="Center" />
                            <TextBlock Grid.Column="3" Text="Total" FontWeight="Medium" Foreground="{DynamicResource SecondaryForeground}" HorizontalAlignment="Right" />
                        </Grid>
                    </Border>

                    <StackPanel Grid.Row="2" Spacing="10">
                        <Border Background="{DynamicResource SurfaceDefault}" BorderBrush="{DynamicResource BorderDefault}" BorderThickness="1" CornerRadius="12" Padding="14">
                            <Grid ColumnDefinitions="2.6*,1.2*,1.2*,1*">
                                <TextBlock Text="Coffee Beans, 1kg" FontSize="14" Foreground="{DynamicResource PrimaryForeground}" />
                                <TextBlock Grid.Column="1" Text="2" HorizontalAlignment="Center" Foreground="{DynamicResource PrimaryForeground}" />
                                <TextBlock Grid.Column="2" Text="125 000" HorizontalAlignment="Center" Foreground="{DynamicResource PrimaryForeground}" />
                                <TextBlock Grid.Column="3" Text="250 000" HorizontalAlignment="Right" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryForeground}" />
                            </Grid>
                        </Border>
                        <Border Background="{DynamicResource SurfaceDefault}" BorderBrush="{DynamicResource BorderDefault}" BorderThickness="1" CornerRadius="12" Padding="14">
                            <Grid ColumnDefinitions="2.6*,1.2*,1.2*,1*">
                                <TextBlock Text="Paper Cup, 350ml" FontSize="14" Foreground="{DynamicResource PrimaryForeground}" />
                                <TextBlock Grid.Column="1" Text="5" HorizontalAlignment="Center" Foreground="{DynamicResource PrimaryForeground}" />
                                <TextBlock Grid.Column="2" Text="2 700" HorizontalAlignment="Center" Foreground="{DynamicResource PrimaryForeground}" />
                                <TextBlock Grid.Column="3" Text="13 500" HorizontalAlignment="Right" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryForeground}" />
                            </Grid>
                        </Border>
                        <Border Background="{DynamicResource SurfaceDefault}" BorderBrush="{DynamicResource BorderDefault}" BorderThickness="1" CornerRadius="12" Padding="14">
                            <Grid ColumnDefinitions="2.6*,1.2*,1.2*,1*">
                                <TextBlock Text="Caramel Syrup" FontSize="14" Foreground="{DynamicResource PrimaryForeground}" />
                                <TextBlock Grid.Column="1" Text="1" HorizontalAlignment="Center" Foreground="{DynamicResource PrimaryForeground}" />
                                <TextBlock Grid.Column="2" Text="38 000" HorizontalAlignment="Center" Foreground="{DynamicResource PrimaryForeground}" />
                                <TextBlock Grid.Column="3" Text="38 000" HorizontalAlignment="Right" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryForeground}" />
                            </Grid>
                        </Border>
                    </StackPanel>

                    <Border Grid.Row="4" Background="{DynamicResource SurfaceHover}" Padding="16" CornerRadius="14">
                        <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="10">
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Text="Subtotal" Foreground="{DynamicResource SecondaryForeground}" />
                                <TextBlock Grid.Column="1" Text="301,500 UZS" FontWeight="Medium" Foreground="{DynamicResource PrimaryForeground}" />
                            </Grid>
                            <Grid Grid.Row="1" ColumnDefinitions="*,Auto">
                                <TextBlock Text="Discount" Foreground="{DynamicResource SecondaryForeground}" />
                                <TextBlock Grid.Column="1" Text="- 11,500 UZS" FontWeight="Medium" Foreground="{DynamicResource PrimaryForeground}" />
                            </Grid>
                            <Grid Grid.Row="2" ColumnDefinitions="*,Auto">
                                <TextBlock Text="Total" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryForeground}" />
                                <TextBlock Grid.Column="1" Text="290,000 UZS" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource AccentBlue}" />
                            </Grid>
                        </Grid>
                    </Border>

                <Border Grid.Row="5" Padding="20" Background="{DynamicResource SurfaceDefault}" CornerRadius="20">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Customer"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryForeground}" />
                        <TextBox Watermark="Name or phone number"
                                 Background="{DynamicResource SurfaceHover}"
                                 BorderBrush="{DynamicResource BorderDefault}"
                                 BorderThickness="1"
                                 CornerRadius="10"
                                 Padding="12" />
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                            <Button Content="New Customer"
                                    Background="{DynamicResource SurfaceActive}"
                                    Foreground="{DynamicResource PrimaryForeground}"
                                    CornerRadius="10"
                                    Padding="10,8" />
                            <Button Grid.Column="1"
                                    Content="History"
                                    Background="{DynamicResource SurfaceDefault}"
                                    BorderBrush="{DynamicResource BorderDefault}"
                                    BorderThickness="1"
                                    Foreground="{DynamicResource PrimaryForeground}"
                                    CornerRadius="10"
                                    Padding="10,8" />
                        </Grid>
                    </StackPanel>
                </Border>
                </Grid>
            </Border>

            <StackPanel Grid.Row="1" Grid.Column="1" Spacing="16">

                <Border Padding="20" Background="{DynamicResource SurfaceDefault}" CornerRadius="20">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Payment"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryForeground}" />
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                            <ToggleButton Content="Cash"
                                          IsChecked="True"
                                          Background="{DynamicResource AccentBlue}"
                                          Foreground="{DynamicResource PrimaryHoverForeground}"
                                          BorderThickness="0"
                                          Padding="10,8"
                                          CornerRadius="10" />
                            <ToggleButton Grid.Column="1"
                                          Content="Card"
                                          Background="{DynamicResource SurfaceHover}"
                                          Foreground="{DynamicResource PrimaryForeground}"
                                          BorderThickness="0"
                                          Padding="10,8"
                                          CornerRadius="10" />
                        </Grid>
                        <Button Content="Complete Sale"
                                Background="{DynamicResource AccentGreen}"
                                Foreground="{DynamicResource PrimaryHoverForeground}"
                                FontSize="16"
                                FontWeight="SemiBold"
                                Padding="12"
                                CornerRadius="12" />
                    </StackPanel>
                </Border>

                <Border Padding="20" Background="{DynamicResource SurfaceDefault}" CornerRadius="20">
                    <StackPanel Spacing="10">
                        <TextBlock Text="NumPad"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryForeground}" />
                        <Border Background="{DynamicResource SurfaceHover}" BorderBrush="{DynamicResource BorderDefault}" BorderThickness="1" CornerRadius="10" Padding="10">
                            <TextBlock Text="0"
                                       FontSize="28"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Right"
                                       Foreground="{DynamicResource PrimaryForeground}" />
                        </Border>
                        <Grid ColumnDefinitions="*,*,*" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="8" ColumnSpacing="8">
                            <Button Content="7" Grid.Row="0" Grid.Column="0" Padding="0,14" CornerRadius="10" Background="{DynamicResource SurfaceHover}" Foreground="{DynamicResource PrimaryForeground}" />
                            <Button Content="8" Grid.Row="0" Grid.Column="1" Padding="0,14" CornerRadius="10" Background="{DynamicResource SurfaceHover}" Foreground="{DynamicResource PrimaryForeground}" />
                            <Button Content="9" Grid.Row="0" Grid.Column="2" Padding="0,14" CornerRadius="10" Background="{DynamicResource SurfaceHover}" Foreground="{DynamicResource PrimaryForeground}" />

                            <Button Content="4" Grid.Row="1" Grid.Column="0" Padding="0,14" CornerRadius="10" Background="{DynamicResource SurfaceHover}" Foreground="{DynamicResource PrimaryForeground}" />
                            <Button Content="5" Grid.Row="1" Grid.Column="1" Padding="0,14" CornerRadius="10" Background="{DynamicResource SurfaceHover}" Foreground="{DynamicResource PrimaryForeground}" />
                            <Button Content="6" Grid.Row="1" Grid.Column="2" Padding="0,14" CornerRadius="10" Background="{DynamicResource SurfaceHover}" Foreground="{DynamicResource PrimaryForeground}" />

                            <Button Content="1" Grid.Row="2" Grid.Column="0" Padding="0,14" CornerRadius="10" Background="{DynamicResource SurfaceHover}" Foreground="{DynamicResource PrimaryForeground}" />
                            <Button Content="2" Grid.Row="2" Grid.Column="1" Padding="0,14" CornerRadius="10" Background="{DynamicResource SurfaceHover}" Foreground="{DynamicResource PrimaryForeground}" />
                            <Button Content="3" Grid.Row="2" Grid.Column="2" Padding="0,14" CornerRadius="10" Background="{DynamicResource SurfaceHover}" Foreground="{DynamicResource PrimaryForeground}" />

                            <Button Content="C" Grid.Row="3" Grid.Column="0" Padding="0,14" CornerRadius="10" Background="{DynamicResource SurfaceActive}" Foreground="{DynamicResource PrimaryForeground}" />
                            <Button Content="0" Grid.Row="3" Grid.Column="1" Padding="0,14" CornerRadius="10" Background="{DynamicResource SurfaceHover}" Foreground="{DynamicResource PrimaryForeground}" />
                            <Button Content="⌫" Grid.Row="3" Grid.Column="2" Padding="0,14" CornerRadius="10" Background="{DynamicResource SurfaceActive}" Foreground="{DynamicResource PrimaryForeground}" />
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Padding="18" Background="{DynamicResource PrimaryGradientBackground}" CornerRadius="20">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Tip"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource SecondaryForeground}" />
                        <TextBlock Text="Press F9 to quickly complete a sale and print receipt."
                                   Foreground="{DynamicResource PrimaryForeground}"
                                   FontSize="13" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
