<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:TradeUz.UI.Controls.Inputs"
        xmlns:dg="clr-namespace:Avalonia.Controls;assembly=Avalonia.Controls.DataGrid">
    <Styles.Resources>
        <x:Double x:Key="FontSizeCaption">12</x:Double>
        <x:Double x:Key="FontSizeBody">14</x:Double>
        <x:Double x:Key="FontSizeBodyLarge">16</x:Double>
        <x:Double x:Key="FontSizeSectionTitle">18</x:Double>
        <x:Double x:Key="FontSizePageTitle">26</x:Double>
        <x:Double x:Key="FontSizeNumericDisplay">28</x:Double>
    </Styles.Resources>

    <Style Selector="TextBlock">
        <Setter Property="FontSize" Value="{DynamicResource FontSizeBody}" />
        <Setter Property="FontWeight" Value="Normal" />
    </Style>

    <Style Selector="Button">
        <Setter Property="FontSize" Value="{DynamicResource FontSizeBody}" />
        <Setter Property="FontWeight" Value="Medium" />
    </Style>

    <Style Selector="TextBox">
        <Setter Property="FontSize" Value="{DynamicResource FontSizeBody}" />
    </Style>

    <Style Selector="CalendarDatePicker">
        <Setter Property="FontSize" Value="{DynamicResource FontSizeBody}" />
        <Setter Property="FontWeight" Value="Medium" />
    </Style>

    <Style Selector="controls|NumericBox">
        <Setter Property="FontSize" Value="{DynamicResource FontSizeBodyLarge}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="MinHeight" Value="36" />
    </Style>

    <Style Selector="controls|NumericBox.AmountInput">
        <Setter Property="FontSize" Value="18" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="TextBox.SearchInput">
        <Setter Property="FontSize" Value="{DynamicResource FontSizeBodyLarge}" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="TextBlock.PageTitle">
        <Setter Property="FontSize" Value="{DynamicResource FontSizePageTitle}" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="TextBlock.SectionTitle">
        <Setter Property="FontSize" Value="{DynamicResource FontSizeSectionTitle}" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="TextBlock.PanelText">
        <Setter Property="FontSize" Value="{DynamicResource FontSizeBodyLarge}" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="TextBlock.NumericDisplay">
        <Setter Property="FontSize" Value="{DynamicResource FontSizeNumericDisplay}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="TextAlignment" Value="Right" />
    </Style>

    <Style Selector="TextBlock.SidebarLabel">
        <Setter Property="FontSize" Value="15" />
        <Setter Property="FontWeight" Value="Medium" />
    </Style>

    <Style Selector="dg|DataGrid">
        <Setter Property="FontSize" Value="{DynamicResource FontSizeBody}" />
    </Style>

    <Style Selector="dg|DataGridColumnHeader">
        <Setter Property="FontSize" Value="{DynamicResource FontSizeCaption}" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="dg|DataGridCell">
        <Setter Property="FontSize" Value="{DynamicResource FontSizeBody}" />
    </Style>
</Styles>
