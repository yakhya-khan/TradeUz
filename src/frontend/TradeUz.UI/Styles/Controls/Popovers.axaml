<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Design.PreviewWith>
    <Border Padding="20" Background="{DynamicResource PrimaryBackground}">
        <Border Classes="PopoverHost">
            <Grid ClipToBounds="False">
                <Border Classes="PopoverAnchor"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Margin="0,2,10,0"
                        RenderTransformOrigin="50%,50%">
                    <Border.RenderTransform>
                        <RotateTransform Angle="45" />
                    </Border.RenderTransform>
                </Border>
                <Border Classes="PopoverSurface"
                        Margin="0,6,0,0">
                    <Border Classes="SegmentedGroup">
                        <StackPanel Orientation="Vertical" Spacing="6">
                            <RadioButton Classes="SegmentOption" GroupName="preview" Content="UZ" IsChecked="True" />
                            <RadioButton Classes="SegmentOption" GroupName="preview" Content="RU" />
                            <RadioButton Classes="SegmentOption" GroupName="preview" Content="EN" />
                        </StackPanel>
                    </Border>
                </Border>
            </Grid>
        </Border>
    </Border>
  </Design.PreviewWith>

    <Style Selector="Border.PopoverHost">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Padding" Value="8,4,8,16" />
    </Style>

    <Style Selector="Border.PopoverSurface">
        <Setter Property="Background" Value="{DynamicResource SurfaceDefault}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderDefault}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="16" />
        <Setter Property="Padding" Value="8" />
        <Setter Property="BoxShadow" Value="0 8 24 0 #24000000" />
    </Style>

    <Style Selector="Border.PopoverAnchor">
        <Setter Property="Width" Value="12" />
        <Setter Property="Height" Value="12" />
        <Setter Property="Background" Value="{DynamicResource SurfaceDefault}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderDefault}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="2" />
    </Style>

    <Style Selector="Border.SegmentedGroup">
        <Setter Property="Background" Value="{DynamicResource SurfaceHover}" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Padding" Value="2" />
    </Style>

    <Style Selector="RadioButton.SegmentOption">
        <Setter Property="MinWidth" Value="26" />
        <Setter Property="MinHeight" Value="20" />
        <Setter Property="Padding" Value="11,6" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Foreground" Value="{DynamicResource SecondaryForeground}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Template">
            <ControlTemplate>
                <Border Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{TemplateBinding CornerRadius}">
                    <ContentPresenter Content="{TemplateBinding Content}"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center" />
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>

    <Style Selector="RadioButton.SegmentOption:pointerover /template/ Border">
        <Setter Property="Background" Value="{DynamicResource SurfaceHover}" />
    </Style>

    <Style Selector="RadioButton.SegmentOption:checked /template/ Border">
        <Setter Property="Background" Value="{DynamicResource SurfaceActive}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AccentBlue}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style Selector="RadioButton.SegmentOption:checked /template/ ContentPresenter">
        <Setter Property="Foreground" Value="{DynamicResource AccentBlue}" />
    </Style>
</Styles>
