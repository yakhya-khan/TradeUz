<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">


  <!-- Backgrounds -->
    <SolidColorBrush x:Key="PrimaryBackground" Color="#171c37"/>
    <SolidColorBrush x:Key="PrimaryHoverBackground" Color="#333B5A"/>
    
    <SolidColorBrush x:Key="SurfaceDefault" Color="#1C2040"/>
    <SolidColorBrush x:Key="SurfaceHover" Color="#181C35"/>
    <SolidColorBrush x:Key="SurfaceActive" Color="#1F2347"/>

    <!-- Borders -->
    <SolidColorBrush x:Key="BorderDefault" Color="#3A3F5C"/>

  <!-- Text -->
    <SolidColorBrush x:Key="PrimaryForeground" Color="#CFCFCF"/>
    <SolidColorBrush x:Key="SecondaryForeground" Color="#B0B3C0"/>
    <SolidColorBrush x:Key="PrimaryHoverForeground" Color="White"/>

  <!--Gradients-->
    <LinearGradientBrush x:Key="PrimaryGradientBackground" StartPoint="0%, 0%" EndPoint="100%, 0%">
        <GradientStop Color="#111214" Offset="0"/>
        <GradientStop Color="#313665" Offset="1"/>
    </LinearGradientBrush>

        <!-- Accent colors -->
    <SolidColorBrush x:Key="AccentTrade" Color="#FF9F43"/>
    <SolidColorBrush x:Key="AccentHome" Color="#88D613"/>
    <SolidColorBrush x:Key="AccentOrders" Color="#009688"/>
    <SolidColorBrush x:Key="AccentSupply" Color="#FF43DE"/>
    
    <SolidColorBrush x:Key="AccentBlue" Color="#4F7CFF"/>
    <SolidColorBrush x:Key="AccentGreen" Color="#4FD18B"/>


</ResourceDictionary>
